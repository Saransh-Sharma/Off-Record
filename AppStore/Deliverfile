# Fastlane Deliver Configuration for OffRecord AI Journal
# Run: fastlane deliver from the project root

app_identifier "com.singularity.offrecord"
username "" # Your Apple ID

# App Store Metadata
name({
  "en-US" => "OffRecord AI Journal"
})

subtitle({
  "en-US" => "Your Private AI Assistant"
})

keywords({
  "en-US" => "diary,journal,voice,AI,private AI assistant,mood,mindfulness,private,mental health,companion,recording"
})

promotional_text({
  "en-US" => "NEW: Friday is your private AI assistant for journaling. See personality, emotion, and thought patterns evolve - all 100% on-device."
})

release_notes({
  "en-US" => "Welcome to OffRecord AI Journal - your private AI voice diary with Friday.\n\n- Record diary entries with your voice\n- AI-powered insights and mood trends\n- Watch Friday evolve as it learns about you\n- Track moods, streaks, and emotional patterns\n- 8 beautiful themes\n- Face ID security\n- Lock Screen & Home Screen widgets\n- Export your journal in multiple formats\n- 100% privacy-first: everything stays on your device"
})

privacy_url "https://offrecord.example.com/privacy"
support_url "https://offrecord.example.com/support"
marketing_url "https://offrecord.example.com"

copyright "2026 OffRecord AI Journal"

primary_category "HEALTH_AND_FITNESS"
secondary_category "LIFESTYLE"

# Pricing
price_tier 0  # Free

# Rating
app_rating_config_path "./AppStore/rating_config.json"

# Auto-release after approval
automatic_release true

# Screenshots path
screenshots_path "./AppStore/screenshots"

# Skip if no metadata changes
skip_metadata false
skip_screenshots false
